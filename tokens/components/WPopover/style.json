{
  "w-popover": {
    "style": {
      "icon": {
        "$value": "{icon.strongest}",
        "$type": "color"
      },
      "label": {
        "$value": "{text.strongest}",
        "$type": "color"
      },
      "wrap": {
        "$value": "{bg.weakest}",
        "$type": "color"
      },
      "stroke": {
        "$value": "{stroke.weak}",
        "$type": "color"
      },
      "shadow": {
        "$value": {
          "x": "{fx.axis.none}",
          "y": "{fx.axis.100}",
          "blur": "{fx.blur.150}",
          "spread": "{fx.spread.n.25}",
          "color": "{bg.shadow.medium}",
          "type": "dropShadow"
        },
        "$type": "shadow"
      }
    },
    "size": {
      "tail": {
        "height": {
          "$value": "{sz.micro.md}",
          "$type": "sizing"
        },
        "width": {
          "$value": "{sz.3xs}",
          "$type": "sizing"
        },
        "border": {
          "$value": "{bw.md}",
          "$type": "borderWidth"
        },
        "gap": {
          "$value": "{sp.none}",
          "$type": "spacing"
        },
        "sp-top": {
          "$value": "{sp.none}",
          "$type": "spacing"
        },
        "sp-right": {
          "$value": "{sp.lg}",
          "$type": "spacing"
        },
        "sp-bottom": {
          "$value": "{sp.none}",
          "$type": "spacing"
        },
        "sp-left": {
          "$value": "{sp.lg}",
          "$type": "spacing"
        }
      },
      "safe": {
        "height": {
          "$value": "{sz.micro.xs}",
          "$type": "sizing"
        },
        "width": {
          "$value": "{sz.xs}",
          "$type": "sizing"
        }
      },
      "box": {
        "min-height": {
          "$value": "{sz.xs}",
          "$type": "sizing"
        },
        "min-width": {
          "$value": "{sz.xs}",
          "$type": "sizing"
        },
        "radius": {
          "$value": "{br.xl}",
          "$type": "borderRadius"
        },
        "border": {
          "$value": "{bw.md}",
          "$type": "borderWidth"
        },
        "gap": {
          "$value": "{sp.none}",
          "$type": "spacing"
        },
        "sp-top": {
          "$value": "{sp.3xs}",
          "$type": "spacing"
        },
        "sp-right": {
          "$value": "{sp.3xs}",
          "$type": "spacing"
        },
        "sp-bottom": {
          "$value": "{sp.3xs}",
          "$type": "spacing"
        },
        "sp-left": {
          "$value": "{sp.3xs}",
          "$type": "spacing"
        },
        "icon": {
          "$value": "{sz.3xs}",
          "$type": "sizing"
        },
        "typography": {
          "$value": "{tp.label.xs.regular}",
          "$type": "typography"
        }
      },
      "wrap": {
        "gap": {
          "$value": "{sp.none}",
          "$type": "spacing"
        },
        "sp-top": {
          "$value": "{sp.none}",
          "$type": "spacing"
        },
        "sp-right": {
          "$value": "{sp.none}",
          "$type": "spacing"
        },
        "sp-bottom": {
          "$value": "{sp.none}",
          "$type": "spacing"
        },
        "sp-left": {
          "$value": "{sp.none}",
          "$type": "spacing"
        }
      }
    }
  }
}
