{
  "WTextOverflow": {
    "wrap": {
      "$value": {
        "borderRadius": "{w-text-overflow.size.wrap.radius}",
        "itemSpacing": "{w-text-overflow.size.wrap.gap}",
        "paddingTop": "{w-text-overflow.size.wrap.sp-top}",
        "paddingRight": "{w-text-overflow.size.wrap.sp-right}",
        "paddingBottom": "{w-text-overflow.size.wrap.sp-bottom}",
        "paddingLeft": "{w-text-overflow.size.wrap.sp-left}"
      },
      "$type": "template"
    },
    "text": {
      "$value": {
        "typography": "{tp.label.xs.regular}",
        "fill": "{text.strongest}"
      },
      "$type": "template"
    }
  }
}
