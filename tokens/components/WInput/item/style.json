{
  "w-input-item": {
    "style": {
      "placeholder": {
        "$value": "{icon.medium}",
        "$type": "color"
      },
      "default": {
        "$value": "{icon.medium}",
        "$type": "color"
      },
      "hover": {
        "$value": "{icon.strongest}",
        "$type": "color"
      },
      "focus": {
        "$value": "{icon.medium}",
        "$type": "color"
      },
      "select": {
        "$value": "{icon.strongest}",
        "$type": "color"
      },
      "typing": {
        "$value": "{icon.strongest}",
        "$type": "color"
      },
      "filled": {
        "$value": "{icon.strongest}",
        "$type": "color"
      },
      "success": {
        "$value": "{icon.strongest}",
        "$type": "color"
      },
      "error": {
        "$value": "{icon.strongest}",
        "$type": "color"
      },
      "disable": {
        "$value": "{state.disable-layer}",
        "$type": "color"
      }
    },
    "size": {
      "sm": {
        "$value": "{cfg.sz.static.2xs}",
        "$type": "sizing"
      },
      "lg": {
        "$value": "{cfg.sz.static.xs}",
        "$type": "sizing"
      },
      "autoheight": {
        "min": {
          "$value": "{cfg.sz.static.2xs}",
          "$type": "sizing"
        },
        "max": {
          "$value": "{cfg.sz.static.xs}",
          "$type": "sizing"
        }
      },
      "wrap": {
        "gap": {
          "$value": "{sp.none}",
          "$type": "spacing"
        },
        "sp-top": {
          "$value": "{sp.none}",
          "$type": "spacing"
        },
        "sp-bottom": {
          "$value": "{sp.none}",
          "$type": "spacing"
        },
        "sp-left": {
          "$value": "{sp.none}",
          "$type": "spacing"
        },
        "sp-right": {
          "$value": "{sp.none}",
          "$type": "spacing"
        }
      }
    }
  }
}
