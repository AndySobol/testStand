            "maxWidth": "{w-input-icon.size.sm}",
            "minHeight": "{w-input-icon.size.sm}",
            "maxHeight": "{w-input-icon.size.sm}"
          },
          "$type": "template"
        },
        "wrap": {
          "$value": {
            "itemSpacing": "{w-input-icon.size.wrap.gap}",
            "paddingTop": "{w-input-icon.size.wrap.sp-top}",
            "paddingBottom": "{w-input-icon.size.wrap.sp-bottom}",
            "paddingRight": "{w-input-icon.size.wrap.sp-right}",
            "paddingLeft": "{w-input-icon.size.wrap.sp-left}"
          },
          "$type": "template"
        }
      },
      "lg": {
        "icon": {
          "$value": {
            "height": "{w-input-icon.size.lg}",
            "width": "{w-input-icon.size.lg}",
            "minWidth": "{w-input-icon.size.lg}",
            "maxWidth": "{w-input-icon.size.lg}",
            "minHeight": "{w-input-icon.size.lg}",
            "maxHeight": "{w-input-icon.size.lg}"
          },
          "$type": "template"
        },
        "wrap": {
          "$value": {
            "itemSpacing": "{w-input-icon.size.wrap.gap}",
            "paddingTop": "{w-input-icon.size.wrap.sp-top}",
            "paddingBottom": "{w-input-icon.size.wrap.sp-bottom}",
