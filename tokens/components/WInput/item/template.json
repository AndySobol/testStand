            "minHeight": "{w-input-icon.size.autoheight.min}",
            "maxHeight": "{w-input-icon.size.autoheight.max}",
            "itemSpacing": "{w-input-icon.size.wrap.gap}",
            "paddingTop": "{w-input-icon.size.wrap.sp-top}",
            "paddingBottom": "{w-input-icon.size.wrap.sp-bottom}",
            "paddingRight": "{w-input-icon.size.wrap.sp-right}",
            "paddingLeft": "{w-input-icon.size.wrap.sp-left}"
          },
          "$type": "template"
        }
      }
