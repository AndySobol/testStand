        "$type": "color",
        "$value": "{text.strongest}"
      },
      "error": {
        "$type": "color",
        "$value": "{text.strongest}"
      },
      "disable": {
        "$type": "color",
        "$value": "{state.disable-layer}"
      }
    },
    "size": {
