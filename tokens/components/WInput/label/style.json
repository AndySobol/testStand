{
  "w-input-label": {
    "style": {
      "placeholder": {
        "$type": "color",
        "$value": "{text.weak}"
      },
      "default": {
        "$type": "color",
        "$value": "{text.medium}"
      },
      "hover": {
        "$type": "color",
        "$value": "{text.strongest}"
      },
      "focus": {
        "$type": "color",
        "$value": "{text.medium}"
      },
      "select": {
        "$type": "color",
