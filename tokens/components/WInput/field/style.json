{
  "w-input-field": {
    "style": {
      "contrast": {
        "wrap": {
          "placeholder": {
            "$value": "{bg.weakest}",
            "$type": "color"
          },
          "default": {
            "$value": "{bg.weakest}",
            "$type": "color"
          },
          "hover": {
            "$value": "{bg.weaker}",
            "$type": "color"
          },
          "focus": {
            "$value": "{bg.weakest}",
            "$type": "color"
          },
          "select": {
            "$value": "{bg.weakest}",
            "$type": "color"
          },
          "typing": {
            "$value": "{bg.weakest}",
            "$type": "color"
          },
          "filled": {
            "$value": "{bg.weakest}",
            "$type": "color"
          },
          "success": {
            "$value": "{bg.weakest}",
            "$type": "color"
          },
          "error": {
            "$value": "{bg.weakest}",
            "$type": "color"
          },
          "disable": {
            "$value": "{state.disable}",
            "$type": "color"
          }
        }
      },
      "soft": {
        "wrap": {
          "placeholder": {
            "$value": "{bg.weaker}",
            "$type": "color"
          },
          "default": {
            "$value": "{bg.weaker}",
            "$type": "color"
          },
          "hover": {
            "$value": "{bg.weakest}",
            "$type": "color"
          },
          "focus": {
            "$value": "{bg.weaker}",
            "$type": "color"
          },
          "select": {
            "$value": "{bg.weaker}",
            "$type": "color"
          },
          "typing": {
            "$value": "{bg.weaker}",
            "$type": "color"
          },
          "filled": {
            "$value": "{bg.weaker}",
            "$type": "color"
          },
          "success": {
            "$value": "{bg.weaker}",
            "$type": "color"
          },
          "error": {
            "$value": "{bg.weaker}",
            "$type": "color"
          },
          "disable": {
            "$value": "{state.disable}",
            "$type": "color"
          }
        }
      }
    },
    "size": {
      "sm": {
        "height": {
          "$value": "{sem.w-input.size.input.min-height}",
          "$type": "sizing"
        },
        "gap": {
          "$value": "{sp.none}",
          "$type": "spacing"
        },
        "sp-top": {
          "$value": "{sp.sm}",
          "$type": "spacing"
        },
        "sp-bottom": {
          "$value": "{sp.sm}",
          "$type": "spacing"
        },
        "sp-left": {
          "$value": "{sp.md}",
          "$type": "spacing"
        },
        "sp-right": {
          "$value": "{sp.md}",
          "$type": "spacing"
        },
        "with-headlabel": {
          "height": {
            "$value": "{sem.w-input.size.input-headlabel.min-height}",
            "$type": "sizing"
          },
          "radius": {
            "$value": "{br.2xl}",
            "$type": "borderRadius"
          }
        }
      },
      "lg": {
        "height": {
          "$value": "{sem.w-input.size.input.max-height}",
          "$type": "sizing"
        },
        "gap": {
          "$value": "{sp.none}",
          "$type": "spacing"
        },
        "sp-top": {
          "$value": "{sp.lg}",
          "$type": "spacing"
        },
        "sp-bottom": {
          "$value": "{sp.lg}",
          "$type": "spacing"
        },
        "sp-left": {
          "$value": "{sp.lg}",
          "$type": "spacing"
        },
        "sp-right": {
          "$value": "{sp.lg}",
          "$type": "spacing"
        },
        "with-headlabel": {
          "height": {
            "$value": "{sem.w-input.size.input-headlabel.max-height}",
            "$type": "sizing"
          },
          "radius": {
            "$value": "{br.big.3xs}",
            "$type": "borderRadius"
          }
        }
      },
      "autoheight": {
        "height-min": {
          "$value": "{sem.w-input.size.input.min-height}",
          "$type": "sizing"
        },
        "height-max": {
          "$value": "{sem.w-input.size.input.max-height}",
          "$type": "sizing"
        },
        "gap": {
          "$value": "{sp.none}",
          "$type": "spacing"
        },
        "sp-top": {
          "$value": "{sp.lg}",
          "$type": "spacing"
        },
        "sp-bottom": {
          "$value": "{sp.lg}",
          "$type": "spacing"
        },
        "sp-left": {
          "$value": "{sp.lg}",
          "$type": "spacing"
        },
        "sp-right": {
          "$value": "{sp.lg}",
          "$type": "spacing"
        },
        "with-headlabel": {
          "height-min": {
            "$value": "{sem.w-input.size.input-headlabel.min-height}",
            "$type": "sizing"
          },
          "height-max": {
            "$value": "{sem.w-input.size.input-headlabel.max-height}",
            "$type": "sizing"
          },
          "radius": {
            "$value": "{br.big.3xs}",
            "$type": "borderRadius"
          }
        }
      }
    }
  }
}
