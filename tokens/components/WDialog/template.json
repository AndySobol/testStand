{
  "WDialog": {
    "component": {
      "wrap": {
        "$value": {
          "minWidth": "{w-dialog.size.wrap.min-width}",
          "borderRadius": "{w-dialog.size.wrap.radius}",
          "itemSpacing": "{w-dialog.size.wrap.gap}",
          "paddingTop": "{w-dialog.size.wrap.sp-top}",
          "paddingRight": "{w-dialog.size.wrap.sp-right}",
          "paddingBottom": "{w-dialog.size.wrap.sp-bottom}",
          "paddingLeft": "{w-dialog.size.wrap.sp-left}",
          "borderWidth": "{w-dialog.size.wrap.border}",
          "borderColor": "{w-dialog.style.stroke}",
          "fill": "{w-dialog.style.wrap}",
          "boxShadow": "{w-dialog.style.shadow}"
        },
        "$type": "template"
      },
      "slot": {
        "header": {
          "title": {
            "$value": {
              "typography": "{w-dialog.size.slot.header.title}",
              "fill": "{w-dialog.style.header.title}"
            },
            "$type": "template"
          },
          "description": {
            "$value": {
              "typography": "{w-dialog.size.slot.header.description}",
              "fill": "{w-dialog.style.header.description}"
            },
            "$type": "template"
          },
          "title-wrap": {
            "$value": {
              "borderRadius": "{w-dialog.size.slot.header.title-wrap.radius}",
              "itemSpacing": "{w-dialog.size.slot.header.title-wrap.gap}",
              "paddingTop": "{w-dialog.size.slot.header.title-wrap.sp-top}",
              "paddingRight": "{w-dialog.size.slot.header.title-wrap.sp-right}",
              "paddingBottom": "{w-dialog.size.slot.header.title-wrap.sp-bottom}",
              "paddingLeft": "{w-dialog.size.slot.header.title-wrap.sp-left}"
            },
            "$type": "template"
          },
          "button-wrap": {
            "$value": {
              "borderRadius": "{w-dialog.size.slot.header.button-wrap.radius}",
              "itemSpacing": "{w-dialog.size.slot.header.button-wrap.gap}",
              "paddingTop": "{w-dialog.size.slot.header.button-wrap.sp-top}",
              "paddingRight": "{w-dialog.size.slot.header.button-wrap.sp-right}",
              "paddingBottom": "{w-dialog.size.slot.header.button-wrap.sp-bottom}",
              "paddingLeft": "{w-dialog.size.slot.header.button-wrap.sp-left}"
            },
            "$type": "template"
          },
          "wrap": {
            "$value": {
              "borderRadius": "{w-dialog.size.slot.header.wrap.radius}",
              "itemSpacing": "{w-dialog.size.slot.header.wrap.gap}",
              "paddingTop": "{w-dialog.size.slot.header.wrap.sp-top}",
              "paddingRight": "{w-dialog.size.slot.header.wrap.sp-right}",
              "paddingBottom": "{w-dialog.size.slot.header.wrap.sp-bottom}",
              "paddingLeft": "{w-dialog.size.slot.header.wrap.sp-left}",
              "borderWidthBottom": "{w-dialog.size.wrap.border}",
              "borderColor": "{w-dialog.style.stroke}"
            },
            "$type": "template"
          }
        },
        "content": {
          "title": {
            "$value": {
              "typography": "{w-dialog.size.slot.content.title}",
              "fill": "{w-dialog.style.content.title}"
            },
            "$type": "template"
          },
          "description": {
            "$value": {
              "typography": "{w-dialog.size.slot.content.description}",
              "fill": "{w-dialog.style.content.text}"
            },
            "$type": "template"
          },
          "wrap": {
            "$value": {
              "maxWidth": "{w-dialog.size.slot.content.max-width}",
              "borderRadius": "{w-dialog.size.slot.content.wrap.radius}",
              "itemSpacing": "{w-dialog.size.slot.content.wrap.gap}",
              "paddingTop": "{w-dialog.size.slot.content.wrap.sp-top}",
              "paddingRight": "{w-dialog.size.slot.content.wrap.sp-right}",
              "paddingBottom": "{w-dialog.size.slot.content.wrap.sp-bottom}",
              "paddingLeft": "{w-dialog.size.slot.content.wrap.sp-left}"
            },
            "$type": "template"
          }
        },
        "footer": {
          "button-wrap": {
            "$value": {
              "borderRadius": "{w-dialog.size.slot.footer.button-wrap.radius}",
              "itemSpacing": "{w-dialog.size.slot.footer.button-wrap.gap}",
              "paddingTop": "{w-dialog.size.slot.footer.button-wrap.sp-top}",
              "paddingRight": "{w-dialog.size.slot.footer.button-wrap.sp-right}",
              "paddingBottom": "{w-dialog.size.slot.footer.button-wrap.sp-bottom}",
              "paddingLeft": "{w-dialog.size.slot.footer.button-wrap.sp-left}"
            },
            "$type": "template"
          },
          "wrap": {
            "$value": {
              "borderRadius": "{w-dialog.size.slot.footer.wrap.radius}",
              "itemSpacing": "{w-dialog.size.slot.footer.wrap.gap}",
              "paddingTop": "{w-dialog.size.slot.footer.wrap.sp-top}",
              "paddingRight": "{w-dialog.size.slot.footer.wrap.sp-right}",
              "paddingBottom": "{w-dialog.size.slot.footer.wrap.sp-bottom}",
              "paddingLeft": "{w-dialog.size.slot.footer.wrap.sp-left}",
              "borderWidthTop": "{w-dialog.size.wrap.border}",
              "borderColor": "{w-dialog.style.stroke}"
            },
            "$type": "template"
          }
        }
      }
    }
  }
}
