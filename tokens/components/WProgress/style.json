{
  "w-progress": {
    "style": {
      "clear": {
        "$value": "{transparent}",
        "$type": "color"
      },
      "progress": {
        "$value": "{accent.medium}",
        "$type": "color"
      },
      "success": {
        "$value": "{success.medium}",
        "$type": "color"
      },
      "error": {
        "$value": "{error.medium}",
        "$type": "color"
      },
      "disable": {
        "$value": "{state.disable}",
        "$type": "color"
      },
      "wrap": {
        "$value": "{bg.weak}",
        "$type": "color"
      },
      "wrap-static": {
        "$value": "{static.white.alpha.weaker}",
        "$type": "color"
      }
    },
    "size": {
      "bar": {
        "item": {
          "min-height": {
            "$value": "{sz.micro.sm}",
            "$type": "sizing"
          },
          "height": {
            "$value": "{sz.micro.md}",
            "$type": "sizing"
          },
          "max-height": {
            "$value": "{sz.micro.lg}",
            "$type": "sizing"
          },
          "radius": {
            "$value": "{br.full}",
            "$type": "borderRadius"
          },
          "not-radius": {
            "$value": "{br.none}",
            "$type": "borderRadius"
          }
        },
        "wrap": {
          "min-height": {
            "$value": "{sz.micro.sm}",
            "$type": "sizing"
          },
          "height": {
            "$value": "{sz.micro.md}",
            "$type": "sizing"
          },
          "max-height": {
            "$value": "{sz.micro.lg}",
            "$type": "sizing"
          },
          "radius": {
            "$value": "{br.full}",
            "$type": "borderRadius"
          },
          "gap": {
            "$value": "{sp.none}",
            "$type": "spacing"
          },
          "sp-top": {
            "$value": "{sp.none}",
            "$type": "spacing"
          },
          "sp-right": {
            "$value": "{sp.none}",
            "$type": "spacing"
          },
          "sp-bottom": {
            "$value": "{sp.none}",
            "$type": "spacing"
          },
          "sp-left": {
            "$value": "{sp.none}",
            "$type": "spacing"
          }
        }
      },
      "circle": {
        "xs": {
          "height": {
            "$value": "{sz.2xs}",
            "$type": "sizing"
          },
          "width": {
            "$value": "{sz.2xs}",
            "$type": "sizing"
          },
          "radius": {
            "$value": "{br.full}",
            "$type": "borderRadius"
          }
        },
        "sm": {
          "height": {
            "$value": "{sz.sm}",
            "$type": "sizing"
          },
          "width": {
            "$value": "{sz.sm}",
            "$type": "sizing"
          },
          "radius": {
            "$value": "{br.full}",
            "$type": "borderRadius"
          }
        }
      }
    }
  }
}
