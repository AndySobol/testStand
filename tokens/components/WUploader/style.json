      "title": {
        "default": {
          "$type": "color",
          "$value": "{text.strongest}"
        },
        "hover": {
          "$type": "color",
          "$value": "{text.strongest}"
        },
        "upload": {
          "$type": "color",
          "$value": "{text.strongest}"
        }
      },
      "description": {
        "default": {
          "$type": "color",
          "$value": "{text.medium}"
        },
        "hover": {
          "$type": "color",
          "$value": "{text.medium}"
        },
        "upload": {
          "$type": "color",
          "$value": "{text.medium}"
        }
      },
      "icon": {
        "default": {
          "$type": "color",
          "$value": "{icon.strongest}"
