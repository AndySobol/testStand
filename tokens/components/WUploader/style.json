        "radius": {
          "$type": "borderRadius",
          "$value": "{br.big.3xs}"
        },
        "border": {
          "$type": "borderWidth",
          "$value": "{bw.md}"
        },
        "gap": {
          "$type": "spacing",
          "$value": "{sp.md}"
        },
        "sp-top": {
          "$type": "spacing",
          "$value": "{sp.xl}"
        },
        "sp-right": {
          "$type": "spacing",
          "$value": "{sp.xl}"
        },
        "sp-bottom": {
          "$type": "spacing",
