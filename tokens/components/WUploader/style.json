        "sp-left": {
          "$type": "spacing",
          "$value": "{sp.xl}"
        },
        "icon": {
          "$type": "sizing",
          "$value": "{sz.sm}"
        }
      },
      "border": {
        "default": {
          "$type": "border",
          "$value": {
            "color": "{w-uploader-area.style.stroke.default}",
            "width": "{w-uploader-area.size.wrap.border}",
            "style": "dashed"
          }
        },
        "hover": {
          "$type": "border",
          "$value": {
            "color": "{w-uploader-area.style.stroke.hover}",
            "width": "{w-uploader-area.size.wrap.border}",
            "style": "dashed"
          }
        },
        "upload": {
          "$type": "border",
          "$value": {
            "color": "{w-uploader-area.style.stroke.upload}",
            "width": "{w-uploader-area.size.wrap.border}",
            "style": "dashed"
          }
        }
