        "hover": {
          "$type": "boxShadow",
          "$value": {
            "x": "{fx.axis.none}",
            "y": "{fx.axis.50}",
            "blur": "{fx.blur.25}",
            "spread": "{fx.blur.none}",
            "color": "{bg.shadow.medium}",
            "type": "dropShadow"
          }
        },
        "upload": {
          "$type": "boxShadow",
          "$value": {
            "x": "{fx.axis.none}",
            "y": "{fx.axis.50}",
            "blur": "{fx.blur.25}",
            "spread": "{fx.blur.none}",
            "color": "{bg.shadow.medium}",
            "type": "dropShadow"
          }
        }
      }
