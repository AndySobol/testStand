{
  "w-layout": {
    "style": {
      "shadow": {
        "none": {
          "$value": {
            "x": "{fx.axis.none}",
            "y": "{fx.axis.none}",
            "blur": "{fx.blur.none}",
            "spread": "{fx.blur.none}",
            "color": "{transparent}",
            "type": "dropShadow"
          },
          "$type": "shadow"
        },
        "window": {
          "$value": {
            "x": "{fx.axis.none}",
            "y": "{fx.axis.50}",
            "blur": "{fx.blur.150}",
            "spread": "{fx.blur.none}",
            "color": "{bg.shadow.medium}",
            "type": "dropShadow"
          },
          "$type": "shadow"
        },
        "side": {
          "$value": {
            "x": "{fx.axis.none}",
            "y": "{fx.axis.50}",
            "blur": "{fx.blur.150}",
            "spread": "{fx.blur.none}",
            "color": "{bg.shadow.medium}",
            "type": "dropShadow"
          },
          "$type": "shadow"
        }
      }
    },
    "size": {
      "none": {
        "$value": "{sp.none}",
        "$type": "spacing"
      },
      "2xs": {
        "$value": "{sp.2xs}",
        "$type": "spacing"
      },
      "xs": {
        "$value": "{sp.xs}",
        "$type": "spacing"
      },
      "sm": {
        "$value": "{sp.sm}",
        "$type": "spacing"
      },
      "md": {
        "$value": "{sp.md}",
        "$type": "spacing"
      },
      "lg": {
        "$value": "{sp.lg}",
        "$type": "spacing"
      },
      "xl": {
        "$value": "{sp.xl}",
        "$type": "spacing"
      },
      "2xl": {
        "$value": "{sp.2xl}",
        "$type": "spacing"
      },
      "3xl": {
        "$value": "{sp.big.xs}",
        "$type": "spacing"
      },
      "4xl": {
        "$value": "{sp.big.sm}",
        "$type": "spacing"
      },
      "5xl": {
        "$value": "{sp.big.md}",
        "$type": "spacing"
      }
    }
  }
}
