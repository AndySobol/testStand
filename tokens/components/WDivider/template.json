          "$type": "composition",
          "$value": {
            "borderWidth": "{w-divider.size.section.border}",
            "borderColor": "{w-divider.style.stroke}"
          }
        },
        "wrap": {
          "$type": "composition",
          "$value": {
            "minHeight": "{w-divider.size.section.min-height}",
            "itemSpacing": "{w-divider.size.section.gap}",
            "paddingTop": "{w-divider.size.section.sp-top}",
            "paddingRight": "{w-divider.size.section.sp-right}",
            "paddingBottom": "{w-divider.size.section.sp-bottom}",
            "paddingLeft": "{w-divider.size.section.sp-left}",
            "fill": "{w-divider.style.wrap}"
          }
        },
        "label": {
          "$type": "composition",
          "$value": {
            "typography": "{w-divider.size.section.typography}",
            "fill": "{w-divider.style.label}"
          }
        }
      },
      "section-content": {
        "vector": {
          "$type": "composition",
