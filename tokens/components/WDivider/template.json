            "borderWidth": "{w-divider.size.section-content.border}",
            "borderColor": "{w-divider.style.stroke}"
          }
        },
        "wrap": {
          "$type": "composition",
          "$value": {
            "minHeight": "{w-divider.size.section-content.min-height}",
            "borderRadius": "{w-divider.size.section-content.radius}",
            "itemSpacing": "{w-divider.size.section-content.gap}",
            "paddingTop": "{w-divider.size.section-content.sp-top}",
            "paddingRight": "{w-divider.size.section-content.sp-right}",
            "paddingBottom": "{w-divider.size.section-content.sp-bottom}",
            "paddingLeft": "{w-divider.size.section-content.sp-left}",
            "fill": "{w-divider.style.wrap}"
