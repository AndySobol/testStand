            "itemSpacing": "{w-divider.size.section.gap}",
            "paddingTop": "{w-divider.size.section.sp-top}",
            "paddingRight": "{w-divider.size.section.sp-right}",
            "paddingBottom": "{w-divider.size.section.sp-bottom}",
            "paddingLeft": "{w-divider.size.section.sp-left}"
          }
        },
        "label": {
          "$type": "composition",
          "$value": {
            "typography": "{w-divider.size.section-content.typography}",
            "fill": "{w-divider.style.label}"
          }
