{
  "WDivider": {
    "component": {
      "clear": {
        "vector": {
          "$type": "composition",
          "$value": {
            "borderWidth": "{w-divider.size.clear.border}",
            "borderColor": "{w-divider.style.stroke}"
          }
        },
        "wrap": {
          "$type": "composition",
          "$value": {
            "minHeight": "{w-divider.size.clear.min-height}",
            "maxHeight": "{w-divider.size.clear.max-height}",
            "itemSpacing": "{w-divider.size.clear.gap}",
            "paddingTop": "{w-divider.size.clear.sp-top}",
            "paddingRight": "{w-divider.size.clear.sp-right}",
            "paddingBottom": "{w-divider.size.clear.sp-bottom}",
            "paddingLeft": "{w-divider.size.clear.sp-left}"
          }
        }
      },
      "separator": {
        "vector": {
          "$type": "composition",
          "$value": {
            "borderWidth": "{w-divider.size.separator.border}",
            "borderColor": "{w-divider.style.stroke}"
          }
        },
        "wrap": {
          "$type": "composition",
          "$value": {
            "minHeight": "{w-divider.size.separator.min-height}",
            "maxHeight": "{w-divider.size.separator.max-height}",
            "itemSpacing": "{w-divider.size.separator.gap}",
            "paddingTop": "{w-divider.size.separator.sp-top}",
            "paddingRight": "{w-divider.size.separator.sp-right}",
            "paddingBottom": "{w-divider.size.separator.sp-bottom}",
            "paddingLeft": "{w-divider.size.separator.sp-left}"
          }
        }
      },
      "section": {
