{
  "WSpinner": {
    "component": {
      "dots": {
        "accent": {
          "$value": {
            "fill": "{w-spinner.style.accent}"
          },
          "$type": "template"
        },
        "neutral": {
          "$value": {
            "fill": "{w-spinner.style.neutral}"
          },
          "$type": "template"
        },
        "staticBlack": {
          "$value": {
            "fill": "{w-spinner.style.static.black}"
          },
          "$type": "template"
        },
        "staticWhite": {
          "$value": {
            "fill": "{w-spinner.style.static.white}"
          },
          "$type": "template"
        }
      },
      "spinner": {
        "accent": {
          "$value": {
            "borderWidth": "{w-spinner.size.spinner.border}",
            "borderColor": "{w-spinner.style.accent}"
          },
          "$type": "template"
        },
        "neutral": {
          "$value": {
            "borderWidth": "{w-spinner.size.spinner.border}",
            "borderColor": "{w-spinner.style.neutral}"
          },
          "$type": "template"
        },
        "staticBlack": {
          "$value": {
            "borderWidth": "{w-spinner.size.spinner.border}",
            "borderColor": "{w-spinner.style.static.black}"
          },
          "$type": "template"
        },
        "staticWhite": {
          "$value": {
            "borderWidth": "{w-spinner.size.spinner.border}",
            "borderColor": "{w-spinner.style.static.white}"
          },
          "$type": "template"
        }
      },
      "wrap": {
        "custom": {
          "$value": {
            "width": "{w-spinner.size.custom.width}",
            "height": "{w-spinner.size.custom.height}"
          },
          "$type": "template"
        },
        "xs": {
          "$value": {
            "width": "{w-spinner.size.xs.width}",
            "height": "{w-spinner.size.xs.height}"
          },
          "$type": "template"
        },
        "sm": {
          "$value": {
            "width": "{w-spinner.size.sm.width}",
            "height": "{w-spinner.size.sm.height}"
          },
          "$type": "template"
        },
        "md": {
          "$value": {
            "width": "{w-spinner.size.md.width}",
            "height": "{w-spinner.size.md.height}"
          },
          "$type": "template"
        },
        "lg": {
          "$value": {
            "width": "{w-spinner.size.lg.width}",
            "height": "{w-spinner.size.lg.height}"
          },
          "$type": "template"
        },
        "xl": {
          "$value": {
            "width": "{w-spinner.size.xl.width}",
            "height": "{w-spinner.size.xl.height}"
          },
          "$type": "template"
        }
      }
    }
  }
}
