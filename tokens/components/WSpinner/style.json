{
  "w-spinner": {
    "style": {
      "accent": {
        "$value": "{accent.medium}",
        "$type": "color"
      },
      "neutral": {
        "$value": "{neutral.medium}",
        "$type": "color"
      },
      "static": {
        "black": {
          "$value": "{static.black.strongest}",
          "$type": "color"
        },
        "white": {
          "$value": "{static.white.strongest}",
          "$type": "color"
        }
      }
    },
    "size": {
      "spinner": {
        "border": {
          "$value": "{bw.xl}",
          "$type": "borderWidth"
        }
      },
      "custom": {
        "height": {
          "$value": "{sz.big.xs}",
          "$type": "sizing"
        },
        "width": {
          "$value": "{sz.big.xs}",
          "$type": "sizing"
        }
      },
      "xs": {
        "height": {
          "$value": "{sz.2xs}",
          "$type": "sizing"
        },
        "width": {
          "$value": "{sz.2xs}",
          "$type": "sizing"
        }
      },
      "sm": {
        "height": {
          "$value": "{sz.xs}",
          "$type": "sizing"
        },
        "width": {
          "$value": "{sz.xs}",
          "$type": "sizing"
        }
      },
      "md": {
        "height": {
          "$value": "{sz.sm}",
          "$type": "sizing"
        },
        "width": {
          "$value": "{sz.sm}",
          "$type": "sizing"
        }
      },
      "lg": {
        "height": {
          "$value": "{sz.md}",
          "$type": "sizing"
        },
        "width": {
          "$value": "{sz.md}",
          "$type": "sizing"
        }
      },
      "xl": {
        "height": {
          "$value": "{sz.xl}",
          "$type": "sizing"
        },
        "width": {
          "$value": "{sz.xl}",
          "$type": "sizing"
        }
      }
    }
  }
}
