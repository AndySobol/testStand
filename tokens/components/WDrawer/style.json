      "main": {
        "$type": "color",
        "$value": "{bg.weakest}"
      },
      "stroke": {
        "$type": "color",
        "$value": "{stroke.weaker}"
      },
      "shadow": {
        "$type": "boxShadow",
        "$value": {
          "x": "{fx.axis.none}",
          "y": "{fx.axis.100}",
          "blur": "{fx.blur.150}",
          "spread": "{fx.spread.n.75}",
