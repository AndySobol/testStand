{
  "w-accordion": {
    "style": {
      "$type": "color",
      "wrap": {
        "contrast": {
          "default": {
            "$value": "{neutral.weakest}"
          },
          "hover": {
            "$value": "{neutral.weaker}"
          },
          "active": {
            "$value": "{neutral.weakest}"
          },
          "focus": {
            "$value": "{neutral.weakest}"
          }
        },
        "soft": {
          "default": {
            "$value": "{neutral.weaker}"
          },
          "hover": {
            "$value": "{neutral.weakly}"
          },
          "active": {
            "$value": "{neutral.weaker}"
          },
          "focus": {
            "$value": "{neutral.weaker}"
          }
        }
      },
      "stroke": {
        "default": {
          "$value": "{stroke.weak}"
        },
        "hover": {
          "$value": "{stroke.weak}"
        },
        "focus": {
          "$value": "{stroke.weak}"
        },
        "active": {
          "$value": "{stroke.weak}"
        }
      },
      "shadow": {
        "$type": "shadow",
        "default": {
          "$value": {
            "x": "{fx.axis.none}",
            "y": "{fx.axis.none}",
            "blur": "{fx.blur.none}",
            "spread": "{fx.blur.none}",
            "color": "{transparent}",
            "type": "dropShadow"
          }
        },
        "hover": {
          "$value": {
            "x": "{fx.axis.none}",
            "y": "{fx.axis.none}",
            "blur": "{fx.blur.none}",
            "spread": "{fx.blur.none}",
            "color": "{transparent}",
            "type": "dropShadow"
          }
        },
        "active": {
          "$value": {
            "x": "{fx.axis.none}",
            "y": "{fx.axis.none}",
            "blur": "{fx.blur.none}",
            "spread": "{fx.blur.none}",
            "color": "{transparent}",
            "type": "dropShadow"
          }
        },
        "focus": {
          "$value": {
            "x": "{fx.axis.none}",
            "y": "{fx.axis.none}",
            "blur": "{fx.blur.none}",
            "spread": "{fx.spread.25}",
            "color": "{accent.medium}",
            "type": "dropShadow"
          }
        }
      }
    },
    "size": {
      "sm": {
        "wrap": {
          "radius": {
            "$value": "{br.2xl}",
            "$type": "borderRadius"
          },
          "gap": {
            "$value": "{sp.md}",
            "$type": "spacing"
          },
          "sp-left": {
            "$value": "{sp.lg}",
            "$type": "spacing"
          },
          "sp-right": {
            "$value": "{sp.lg}",
            "$type": "spacing"
          },
          "sp-top": {
            "$value": "{sp.lg}",
            "$type": "spacing"
          },
          "sp-bottom": {
            "$value": "{sp.lg}",
            "$type": "spacing"
          },
          "border": {
            "$value": "{bw.md}",
            "$type": "borderWidth"
          }
        }
      },
      "xs": {
        "wrap": {
          "radius": {
            "$value": "{br.lg}",
            "$type": "borderRadius"
          },
          "gap": {
            "$value": "{sp.xs}",
            "$type": "spacing"
          },
          "sp-left": {
            "$value": "{sp.md}",
            "$type": "spacing"
          },
          "sp-right": {
            "$value": "{sp.md}",
            "$type": "spacing"
          },
          "sp-top": {
            "$value": "{sp.md}",
            "$type": "spacing"
          },
          "sp-bottom": {
            "$value": "{sp.md}",
            "$type": "spacing"
          },
          "border": {
            "$value": "{bw.md}",
            "$type": "borderWidth"
          }
        }
      }
    }
  }
}
