{
  "w-skeleton": {
    "style": {
      "wrap": {
        "$type": "color",
        "$value": "{bg.weak}"
      },
      "wave": {
        "black": {
          "$type": "color",
          "$value": "linear-gradient(90deg, {transparent} 0%, {neutral.alpha.medium} 48%, {transparent} 100%)"
        },
        "white": {
          "$type": "color",
          "$value": "linear-gradient(90deg, {transparent} 0%, {static.white.alpha.strong} 48%, {transparent} 100%)"
        }
      }
    },
    "component": {
      "wave": {
        "black": {
          "$type": "composition",
          "$value": {
            "width": "100",
            "height": "48",
            "fill": "{w-skeleton.style.wave.black}"
          }
        },
        "white": {
          "$type": "composition",
          "$value": {
            "width": "100",
            "height": "48",
            "fill": "{w-skeleton.style.wave.white}"
          }
        }
      },
      "vector-wrap": {
        "$type": "composition",
        "$value": {
          "fill": "{w-skeleton.style.wrap}"
        }
      }
    }
  }
}